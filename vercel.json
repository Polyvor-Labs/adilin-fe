{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://151.243.222.93:37990/api/:path*"
    },
    {
      "source": "/health",
      "destination": "http://151.243.222.93:37990/health"
    },
    {
      "source": "/ai",
      "destination": "/ai/index.html"
    }
  ],
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
